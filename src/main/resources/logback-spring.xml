<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Variables -->
    <property name="LOG_DIR" value="logs" />
    <property name="APP_NAME" value="sigeclin" />

    <!-- Salida a Consola (para desarrollo) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Archivo General (Rotativo) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Rotación diaria -->
            <fileNamePattern>${LOG_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- Mantener 30 días de historial operativo -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Archivo Estricto de Auditoría de Seguridad (A09:2021) -->
    <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/security-audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/security-audit.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- Retención de grado médico forense (90 días) -->
            <maxHistory>90</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Asignar eventos de seguridad exclusivamente al archivo especial -->
    <logger name="org.springframework.security" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="SECURITY_FILE" />
    </logger>
    
    <logger name="com.sigeclin.config.AuthenticationEvents" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="SECURITY_FILE" />
    </logger>
    
    <logger name="com.sigeclin.seguridad" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="SECURITY_FILE" />
    </logger>

    <!-- Raíz del sistema -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>
</configuration>
